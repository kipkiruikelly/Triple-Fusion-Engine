# BullLogic environment configuration
# Copy to .env (or set in the NSSM service environment) and fill in real values.
# Never commit the real .env.

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
# DATABASE_URL=sqlite:///absolute/path/to/users.db   # optional, defaults to instance/users.db
WEB_THREADS=24
SECURE_COOKIES=true            # true when serving over HTTPS only (Caddy)
ADMIN_SESSION_MINUTES=30

# ── Pyth Network oracle (price verification + failover) ─────────────────────
# Works without a key today. Hermes makes authentication MANDATORY on
# 31 July 2026: create a key at https://pyth.network before then.
PYTH_API_KEY=
# PYTH_HERMES_URL=https://hermes.pyth.network   # override for self-hosted Hermes

# ── Google OAuth 2.0 (Continue with Google) ──────────────────────────────────
# Create at https://console.cloud.google.com > APIs & Services > Credentials
# Leave blank to hide the Google button entirely.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Flask-Mail over SMTP) ─────────────────────────────────────────────
# Option A, Gmail: MAIL_SERVER=smtp.gmail.com, MAIL_USERNAME=you@gmail.com,
#   MAIL_PASSWORD=16-char app password (myaccount.google.com/apppasswords)
# Option B, Brevo (recommended for production): MAIL_SERVER=smtp-relay.brevo.com,
#   MAIL_USERNAME=your Brevo SMTP login, MAIL_PASSWORD=your Brevo SMTP key
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=BullLogic <noreply@yourdomain.com>

# ── M-Pesa (Safaricom Daraja) ────────────────────────────────────────────────
# sandbox: test credentials from developer.safaricom.co.ke
# production: credentials issued after Go-Live approval
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-public-domain/mpesa/callback
PRO_MONTHLY_KES=3500
PRO_ANNUAL_KES=23000

# ── Stripe (optional card payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# ── Market data / storage / misc ─────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
AZURE_STORAGE_CONNECTION_STRING=
ANTHROPIC_API_KEY=
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
TELEGRAM_BOT_TOKEN=            # optional, enables Telegram alerts

# ── Runtime / service knobs (rarely changed) ─────────────────────────────────
# HOST=0.0.0.0                 # bind address for the dev server
# PORT=5000                    # port for the dev server / waitress
# FLASK_DEBUG=false            # never true in production
# DISABLE_OPS_THREAD=false     # true only in tests/audits
# ADMIN_ROLE=admin             # role granted to the seeded admin account
# MAIL_USER=                   # legacy alias used by the standalone paper_trader.py CLI
# MAIL_FROM=                   # legacy alias used by the standalone paper_trader.py CLI
