# Triple-Fusion-Engine environment configuration
# Copy to .env (or set in Docker / NSSM service environment) and fill in real values.
# Never commit the real .env.

# ── Environment ──────────────────────────────────────────────────────────────
ENV=development              # development | staging | production

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
# DATABASE_URL=sqlite:///absolute/path/to/users.db   # optional, defaults to instance/users.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/tfe   # production
WEB_THREADS=24
SECURE_COOKIES=true            # true when serving over HTTPS only (Caddy)
ADMIN_SESSION_MINUTES=30

# ── Data Pipeline ────────────────────────────────────────────────────────────
# DEFAULT_TICKER=QQQ
# DEFAULT_TICKERS=["QQQ","SPY","AAPL","MSFT","NVDA"]   # JSON array for multi-ticker
# START_DATE=1999-01-01
# END_DATE=2026-06-01
# LOOKBACK=60
# TRAIN_RATIO=0.80
# MAX_PARALLEL_FETCHES=5
# INTRADAY_INTERVALS=["1m","5m","15m","30m","1h","4h"]

# ── Model Training ───────────────────────────────────────────────────────────
# RF_N_ESTIMATORS=300
# RF_MAX_DEPTH=12
# XGB_N_ESTIMATORS=300
# LSTM_EPOCHS=80
# LSTM_BATCH_SIZE=32
# CV_FOLDS=5

# ── Trading Engine ───────────────────────────────────────────────────────────
TRADING_MODE=paper             # paper | metaapi | mt5linux
# MAX_POSITIONS=3
# DAILY_LOSS_LIMIT=0.05        # 5% equity drawdown halts trading
# PAPER_BALANCE=10000.0
# RISK_PCT=1.0                 # risk 1% of equity per trade
# SL_ATR_MULT=1.5
# TP_ATR_MULT=2.5
# MAX_HOLD_BARS=10

# ── Messaging / Redis ────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
# USE_REDIS=false               # set to true to enable Redis pub/sub

# ── Pyth Network oracle (price verification + failover) ─────────────────────
PYTH_API_KEY=
# PYTH_HERMES_URL=https://hermes.pyth.network

# ── Google OAuth 2.0 (Continue with Google) ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Flask-Mail over SMTP) ─────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=BullLogic <noreply@yourdomain.com>

# ── M-Pesa (Safaricom Daraja) ────────────────────────────────────────────────
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-public-domain/mpesa/callback
PRO_MONTHLY_KES=3500
PRO_ANNUAL_KES=23000

# ── Stripe (optional card payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=
STRIPE_WEBHOOK_SECRET=

# ── Live trading safety gate ─────────────────────────────────────────────────
# Real order execution (MetaApi or MT5 bridge) is REFUSED unless this is
# explicitly set to true. Leave it unset/false for paper-only operation.
ENABLE_LIVE_TRADING=false

# ── MetaApi (MT5 cloud broker) ───────────────────────────────────────────────
METAAPI_TOKEN=
METAAPI_ACCOUNT_ID=

# ── External APIs ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
AZURE_STORAGE_CONNECTION_STRING=

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
