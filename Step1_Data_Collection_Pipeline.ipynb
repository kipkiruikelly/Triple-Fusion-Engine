   "source": [
    "## 🔗 CELL 9: Correlation Analysis\n",
    "Check how strongly each feature correlates with tomorrow's closing price (our regression target) and with the Direction (our classification target)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Correlation heatmap ───────────────────────────────────────\n",
    "# Select only numeric feature columns (exclude raw OHLCV for clarity)\n",
    "feature_cols = ['SMA_7', 'SMA_21', 'EMA_12', 'EMA_26',\n",
