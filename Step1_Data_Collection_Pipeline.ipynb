   "source": [
    "## 🔢 CELL 11: Feature Scaling\n",
    "Machine learning models — especially LSTM — are sensitive to the scale of input features. We normalise all features to the range [0, 1] using MinMaxScaler.\n",
    "\n",
    "> **Critical rule:** The scaler is fitted ONLY on the training set. It is then applied to validation and test sets. Fitting on the full dataset would leak test information into training."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import MinMaxScaler\n",
    "import joblib\n",
    "\n",
    "# ── Fit scaler on training data only ──────────────────────────\n",
    "scaler = MinMaxScaler(feature_range=(0, 1))\n",
    "\n",
    "X_train_scaled = scaler.fit_transform(df_train[MODEL_FEATURES])\n",
    "X_val_scaled   = scaler.transform(df_val[MODEL_FEATURES])\n",
    "X_test_scaled  = scaler.transform(df_test[MODEL_FEATURES])\n",
    "\n",
    "# ── Also scale just the Close column for inverse-transforming predictions ──\n",
    "close_idx = MODEL_FEATURES.index('Close')\n",
    "print(f\"   Close column index in feature matrix: {close_idx}\")\n",
    "\n",
    "# ── Save the scaler for use in Flask app ──────────────────────\n",
    "joblib.dump(scaler, f'{OUTPUT_DIR}/scaler_{TICKER}.pkl')\n",
    "joblib.dump(MODEL_FEATURES, f'{OUTPUT_DIR}/feature_cols_{TICKER}.pkl')\n",
    "\n",
    "print(\"── Scaling Summary ─────────────────────────────────────\")\n",
    "print(f\"   Features scaled  : {len(MODEL_FEATURES)}\")\n",
    "print(f\"   Train shape      : {X_train_scaled.shape}\")\n",
    "print(f\"   Validation shape : {X_val_scaled.shape}\")\n",
    "print(f\"   Test shape       : {X_test_scaled.shape}\")\n",
    "print(f\"   Scaler saved to  : {OUTPUT_DIR}/scaler_{TICKER}.pkl\")\n",
    "print(\"✅ Scaling complete.\")"
   ]
