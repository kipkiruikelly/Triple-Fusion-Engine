   "source": [
    "## ✂️ CELL 10: Train / Validation / Test Split\n",
    "We split the data **chronologically** — never randomly. Shuffling time-series data would leak future information into training, making results misleadingly optimistic."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Define the feature columns used for modelling ─────────────\n",
    "# We exclude Direction from model inputs (it is a target, not a feature)\n",
    "MODEL_FEATURES = [\n",
    "    'Open', 'High', 'Low', 'Close', 'Volume',\n",
    "    'SMA_7', 'SMA_21', 'EMA_12', 'EMA_26',\n",
    "    'RSI_14', 'MACD', 'MACD_Signal', 'MACD_Hist',\n",
    "    'BB_Upper', 'BB_Lower', 'BB_Mid', 'BB_Width',\n",
    "    'Volume_SMA_10', 'Daily_Return'\n",
    "]\n",
    "\n",
    "TARGET_REGRESSION     = 'Close'      # Next-day price (shifted during sequence building)\n",
    "TARGET_CLASSIFICATION = 'Direction'  # Up (1) or Down (0)\n",
    "\n",
    "# ── Chronological split ───────────────────────────────────────\n",
    "n = len(df_featured)\n",
    "train_end = int(n * TRAIN_RATIO)\n",
    "val_end   = int(n * (TRAIN_RATIO + VAL_RATIO))\n",
    "\n",
    "df_train = df_featured.iloc[:train_end]\n",
    "df_val   = df_featured.iloc[train_end:val_end]\n",
    "df_test  = df_featured.iloc[val_end:]\n",
    "\n",
    "print(\"── Chronological Split ─────────────────────────────────\")\n",
    "print(f\"   Training   : {len(df_train):>5,} rows  ({df_train.index.min().date()} → {df_train.index.max().date()})\")\n",
    "print(f\"   Validation : {len(df_val):>5,} rows  ({df_val.index.min().date()}   → {df_val.index.max().date()})\")\n",
    "print(f\"   Test       : {len(df_test):>5,} rows  ({df_test.index.min().date()}   → {df_test.index.max().date()})\")\n",
    "print(f\"\\n   Direction balance (full dataset):\")\n",
    "direction_counts = df_featured['Direction'].value_counts(normalize=True) * 100\n",
    "print(f\"     Up   (1): {direction_counts.get(1, 0):.1f}%\")\n",
    "print(f\"     Down (0): {direction_counts.get(0, 0):.1f}%\")\n",
    "\n",
    "# ── Visualise the split ───────────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(14, 4))\n",
    "ax.plot(df_train.index, df_train['Close'], color='#1F4E79',  lw=1.5, label=f'Train ({len(df_train):,} days)')\n",
    "ax.plot(df_val.index,   df_val['Close'],   color='#F39C12',  lw=1.5, label=f'Validation ({len(df_val):,} days)')\n",
    "ax.plot(df_test.index,  df_test['Close'],  color='#E74C3C',  lw=1.5, label=f'Test ({len(df_test):,} days)')\n",
    "ax.axvline(df_val.index[0],  color='#F39C12', linestyle='--', lw=1, alpha=0.6)\n",
    "ax.axvline(df_test.index[0], color='#E74C3C', linestyle='--', lw=1, alpha=0.6)\n",
    "ax.set_title(f'{TICKER} — Train / Validation / Test Split', fontweight='bold', fontsize=13)\n",
    "ax.set_ylabel('Close Price (USD)')\n",
    "ax.set_xlabel('Date')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{OUTPUT_DIR}/{TICKER}_train_val_test_split.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Split visualised and saved.\")"
   ]
