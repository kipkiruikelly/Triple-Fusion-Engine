   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧱 CELL 12: Build LSTM Sequences\n",
    "LSTMs require 3D input: `(samples, timesteps, features)`. We build overlapping windows of `LOOKBACK` trading days."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def build_sequences(scaled_data: np.ndarray,\n",
    "                    target_series: np.ndarray,\n",
    "                    lookback: int) -> tuple:\n",
    "    \"\"\"\n",
    "    Build overlapping LSTM input sequences.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    scaled_data   : np.ndarray   2D array of shape (n_samples, n_features)\n",
    "    target_series : np.ndarray   1D array of target values (Close prices)\n",
    "    lookback      : int          Number of previous days used as context\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    X : np.ndarray   Shape (n_samples - lookback, lookback, n_features)\n",
    "    y : np.ndarray   Shape (n_samples - lookback,)\n",
    "    \"\"\"\n",
    "    X, y = [], []\n",
    "    for i in range(lookback, len(scaled_data)):\n",
    "        X.append(scaled_data[i - lookback : i])   # Previous LOOKBACK days\n",
    "        y.append(target_series[i])                 # Next day's close\n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "\n",
    "# ── Extract target (Close price column, scaled) ────────────────\n",
    "y_train_raw = X_train_scaled[:, close_idx]\n",
    "y_val_raw   = X_val_scaled[:, close_idx]\n",
    "y_test_raw  = X_test_scaled[:, close_idx]\n",
    "\n",
    "# ── Build sequences ───────────────────────────────────────────\n",
    "X_train_seq, y_train_seq = build_sequences(X_train_scaled, y_train_raw, LOOKBACK)\n",
    "X_val_seq,   y_val_seq   = build_sequences(X_val_scaled,   y_val_raw,   LOOKBACK)\n",
    "X_test_seq,  y_test_seq  = build_sequences(X_test_scaled,  y_test_raw,  LOOKBACK)\n",
    "\n",
    "print(\"── Sequence Building Summary ───────────────────────────\")\n",
    "print(f\"   Lookback window  : {LOOKBACK} trading days\")\n",
    "print(f\"   X_train shape    : {X_train_seq.shape}  (samples, timesteps, features)\")\n",
    "print(f\"   X_val shape      : {X_val_seq.shape}\")\n",
    "print(f\"   X_test shape     : {X_test_seq.shape}\")\n",
    "print(f\"   y_train shape    : {y_train_seq.shape}\")\n",
    "print(\"✅ Sequences built successfully.\")\n",
    "\n",
    "# ── Save sequences for model training notebook ────────────────\n",
    "np.save(f'{OUTPUT_DIR}/X_train_{TICKER}.npy', X_train_seq)\n",
    "np.save(f'{OUTPUT_DIR}/X_val_{TICKER}.npy',   X_val_seq)\n",
    "np.save(f'{OUTPUT_DIR}/X_test_{TICKER}.npy',  X_test_seq)\n",
    "np.save(f'{OUTPUT_DIR}/y_train_{TICKER}.npy', y_train_seq)\n",
    "np.save(f'{OUTPUT_DIR}/y_val_{TICKER}.npy',   y_val_seq)\n",
    "np.save(f'{OUTPUT_DIR}/y_test_{TICKER}.npy',  y_test_seq)\n",
    "df_featured.to_csv(f'{OUTPUT_DIR}/{TICKER}_featured.csv')\n",
    "\n",
    "print(f\"\\n✅ All data saved to: {OUTPUT_DIR}\")\n",
    "print(\"   Files saved:\")\n",
    "for f in os.listdir(OUTPUT_DIR):\n",
    "    size = os.path.getsize(f'{OUTPUT_DIR}/{f}') / 1024\n",
    "    print(f\"     {f:<45} ({size:.1f} KB)\")"
   ]
