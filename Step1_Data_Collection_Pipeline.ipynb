   "source": [
    "## 🧹 CELL 6: Data Cleaning\n",
    "We handle missing values, duplicates, and zero-volume days (market holidays that sometimes slip through)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def clean_stock_data(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Clean raw OHLCV stock data.\n",
    "\n",
    "    Steps performed:\n",
    "    1. Remove exact duplicate rows\n",
    "    2. Remove rows where all OHLCV values are NaN\n",
    "    3. Forward-fill remaining NaN values (market data gaps)\n",
    "    4. Remove rows where Volume == 0 (non-trading days)\n",
    "    5. Sort by date ascending\n",
    "    6. Reset index\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    pd.DataFrame   Cleaned OHLCV DataFrame\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    "    original_len = len(df)\n",
    "\n",
    "    # Step 1: Remove duplicates\n",
    "    df = df[~df.index.duplicated(keep='first')]\n",
    "    dup_removed = original_len - len(df)\n",
    "\n",
    "    # Step 2: Drop rows where all OHLCV are NaN\n",
    "    df.dropna(how='all', inplace=True)\n",
    "\n",
    "    # Step 3: Forward-fill remaining NaN values\n",
    "    df.ffill(inplace=True)\n",
    "\n",
    "    # Step 4: Remove zero-volume rows\n",
    "    zero_vol = (df['Volume'] == 0).sum()\n",
    "    df = df[df['Volume'] > 0]\n",
    "\n",
    "    # Step 5: Sort by date\n",
    "    df.sort_index(inplace=True)\n",
    "\n",
    "    final_len = len(df)\n",
    "\n",
    "    print(\"── Cleaning Summary ────────────────────────────────────\")\n",
    "    print(f\"   Original rows      : {original_len:,}\")\n",
    "    print(f\"   Duplicates removed : {dup_removed}\")\n",
    "    print(f\"   Zero-volume removed: {zero_vol}\")\n",
    "    print(f\"   Final rows         : {final_len:,}\")\n",
    "    print(f\"   Remaining NaNs     : {df.isnull().sum().sum()}\")\n",
    "    print(\"✅ Cleaning complete.\")\n",
    "    return df\n",
    "\n",
    "\n",
    "# ── Run cleaning ───────────────────────────────────────────────\n",
    "df_clean = clean_stock_data(df_raw)\n",
    "display(df_clean.head())"
   ]
  },
