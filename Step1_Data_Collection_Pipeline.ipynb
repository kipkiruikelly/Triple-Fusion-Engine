   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📐 CELL 7: Feature Engineering\n",
    "We compute all technical indicator features that will be used as model inputs. Each indicator captures a different aspect of market behaviour — trend, momentum, or volatility."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def engineer_features(df: pd.DataFrame) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Engineer technical indicator features from OHLCV data.\n",
    "\n",
    "    Features computed\n",
    "    -----------------\n",
    "    Trend       : SMA_7, SMA_21, EMA_12, EMA_26\n",
    "    Momentum    : RSI_14, MACD, MACD_Signal, MACD_Hist\n",
    "    Volatility  : BB_Upper, BB_Lower, BB_Mid, BB_Width\n",
    "    Volume      : Volume_SMA_10 (volume moving average)\n",
    "    Return      : Daily_Return (% change in close price)\n",
    "    Target      : Direction (1 = next day Up, 0 = next day Down)\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    pd.DataFrame   DataFrame with all original and engineered columns\n",
    "    \"\"\"\n",
    "    df = df.copy()\n",
    "\n",
    "    # ── TREND INDICATORS ──────────────────────────────────────\n",
    "    # Simple Moving Averages\n",
    "    df['SMA_7']  = ta.sma(df['Close'], length=7)\n",
    "    df['SMA_21'] = ta.sma(df['Close'], length=21)\n",
    "\n",
    "    # Exponential Moving Averages (used internally by MACD)\n",
    "    df['EMA_12'] = ta.ema(df['Close'], length=12)\n",
    "    df['EMA_26'] = ta.ema(df['Close'], length=26)\n",
    "\n",
    "    # ── MOMENTUM INDICATORS ───────────────────────────────────\n",
    "    # RSI — Relative Strength Index (14-period)\n",
    "    # Values above 70 = overbought; below 30 = oversold\n",
    "    df['RSI_14'] = ta.rsi(df['Close'], length=14)\n",
    "\n",
    "    # MACD — Moving Average Convergence Divergence\n",
    "    macd_result = ta.macd(df['Close'], fast=12, slow=26, signal=9)\n",
    "    df['MACD']        = macd_result['MACD_12_26_9']\n",
    "    df['MACD_Signal'] = macd_result['MACDs_12_26_9']\n",
    "    df['MACD_Hist']   = macd_result['MACDh_12_26_9']\n",
    "\n",
    "    # ── VOLATILITY INDICATORS ─────────────────────────────────\n",
    "    # Bollinger Bands (20-period, 2 standard deviations)\n",
    "    bb_result = ta.bbands(df['Close'], length=20, std=2)\n",
    "    df['BB_Upper'] = bb_result['BBU_20_2.0']\n",
    "    df['BB_Lower'] = bb_result['BBL_20_2.0']\n",
    "    df['BB_Mid']   = bb_result['BBM_20_2.0']\n",
    "    # Bandwidth — measures volatility level\n",
    "    df['BB_Width'] = (df['BB_Upper'] - df['BB_Lower']) / df['BB_Mid']\n",
    "\n",
    "    # ── VOLUME INDICATOR ──────────────────────────────────────\n",
    "    # 10-day volume moving average (normalises volume spikes)\n",
    "    df['Volume_SMA_10'] = ta.sma(df['Volume'], length=10)\n",
    "\n",
    "    # ── RETURN FEATURE ────────────────────────────────────────\n",
    "    # Daily percentage return\n",
    "    df['Daily_Return'] = df['Close'].pct_change() * 100\n",
    "\n",
    "    # ── TARGET VARIABLE ───────────────────────────────────────\n",
    "    # Direction: 1 if tomorrow's close > today's close, else 0\n",
    "    # shift(-1) looks one day into the future\n",
    "    df['Direction'] = (df['Close'].shift(-1) > df['Close']).astype(int)\n",
    "\n",
    "    # ── DROP ROWS WITH NaN ────────────────────────────────────\n",
    "    # NaNs appear at the start due to indicator warm-up periods\n",
    "    # and at the end due to the Direction shift\n",
    "    rows_before = len(df)\n",
    "    df.dropna(inplace=True)\n",
    "    rows_after = len(df)\n",
    "\n",
    "    print(\"── Feature Engineering Summary ─────────────────────────\")\n",
    "    print(f\"   Input rows    : {rows_before:,}\")\n",
    "    print(f\"   Rows dropped  : {rows_before - rows_after} (indicator warm-up + target shift)\")\n",
    "    print(f\"   Final rows    : {rows_after:,}\")\n",
    "    print(f\"   Total features: {len(df.columns)} columns\")\n",
    "    print(f\"   Features list : {list(df.columns)}\")\n",
    "    print(\"✅ Feature engineering complete.\")\n",
    "    return df\n",
    "\n",
    "\n",
    "# ── Run feature engineering ────────────────────────────────────\n",
    "df_featured = engineer_features(df_clean)\n",
    "display(df_featured.tail())"
   ]
  },
  {
