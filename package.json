{
  "name": "triple-fusion-engine",
  "version": "1.0.0",
  "private": true,
  "description": "Triple Fusion Engine — monorepo dev runner",
  "scripts": {
    "dev": "concurrently --names \"DJANGO,VITE\" --prefix-colors \"yellow,cyan\" \"npm run backend\" \"npm run frontend\"",
    "backend": ".venv\\Scripts\\python.exe django_backend\\manage.py runserver 0.0.0.0:8001",
    "frontend": "cd frontend && npm run dev",
    "install:frontend": "cd frontend && npm install",
    "build": "cd frontend && npm run build"
  }
}
